# ─────────────────────────────────────────────────────────────────────────────
# AI Trading Agent — Environment Configuration
# Copy to .env and fill in your keys.
# ─────────────────────────────────────────────────────────────────────────────

# PAPER = paper trading (safe), LIVE = real money (careful!)
TRADING_MODE=PAPER

# ── Alpaca Markets (https://alpaca.markets) ───────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key

# ── Finnhub (https://finnhub.io) ─────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_api_key

# ── Alpha Vantage (https://www.alphavantage.co) ───────────────────────────────
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key

# ── Groq (https://console.groq.com) ──────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# ── Gemini (https://aistudio.google.com/apikey) ───────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3-flash-preview

# ── Supabase (https://supabase.com) ──────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── Agent behaviour ───────────────────────────────────────────────────────────
# How often the agent runs its analysis loop (seconds)
AGENT_LOOP_INTERVAL_SECONDS=60

# Tickers to watch (JSON array)
WATCHLIST_RAW=["AAPL","MSFT","NVDA","TSLA","SPY"]

# Safety constraints (do not exceed these)
MAX_POSITION_SIZE_PCT=0.02   # 2% of equity per trade
DAILY_LOSS_LIMIT_PCT=0.015   # 1.5% daily loss circuit-breaker

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000
